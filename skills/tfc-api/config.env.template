# agent-skills config template — tfc-api skill
# Copy/rename to tfc-api.env, fill in values, chmod 600.
# Format: KEY=value (bash-compatible). Comments and blank lines are ignored.

# Terraform Cloud organisation name
# Find it at: https://app.terraform.io → Settings → General
#TFC_ORG=your-tfc-org

# Default workspace name (optional — most scripts accept workspace as argument)
#TFC_WORKSPACE=

# TFC token — prefer ~/.terraform.d/credentials.tfrc.json (set by `terraform login`)
# Only uncomment if you cannot use the credentials file
#TFC_TOKEN=
