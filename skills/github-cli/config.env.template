# agent-skills config template — github-cli skill
# Copy/rename to github-cli.env, fill in values, chmod 600.
# Format: KEY=value (bash-compatible). Comments and blank lines are ignored.

# Default GitHub org for operations when not inferred from git remote
#GH_ORG=your-org

# GitHub Projects V2 — discover IDs with:
#   gh api graphql -f query='{ organization(login:"$GH_ORG") { projectsV2(first:10) { nodes { id title number } } } }'
#GH_PROJECT_ID=PVT_kwDO...
#GH_PROJECT_NUMBER=0
#GH_PROJECT_URL=https://github.com/orgs/your-org/projects/0

# Field IDs — stable, query once per project with:
#   gh api graphql -f query='{ node(id:"$GH_PROJECT_ID") { ... on ProjectV2 { fields(first:20) { nodes { ... on ProjectV2FieldCommon { id name } } } } } }'
#GH_FIELD_STATUS=PVTSSF_...
#GH_FIELD_PRIORITY=PVTSSF_...
#GH_FIELD_SIZE=PVTSSF_...
#GH_FIELD_ITERATION=PVTIF_...
#GH_FIELD_START_DATE=PVTF_...
#GH_FIELD_TARGET_DATE=PVTF_...
#GH_FIELD_ESTIMATE=PVTF_...

# Status option IDs (single-select) — project-specific
#GH_STATUS_TODO=
#GH_STATUS_IN_PROGRESS=
#GH_STATUS_DONE=
#GH_STATUS_BACKLOG=
#GH_STATUS_BLOCKED=

# Priority option IDs
#GH_PRIORITY_DEFAULT=
#GH_PRIORITY_P0=
#GH_PRIORITY_P1=
#GH_PRIORITY_P2=

# Size option IDs
#GH_SIZE_XS=
#GH_SIZE_S=
#GH_SIZE_M=
#GH_SIZE_L=
#GH_SIZE_XL=

# Iteration IDs — rotate on cadence, refresh with:
#   gh api graphql -f query='{ node(id:"$GH_PROJECT_ID") { ... on ProjectV2 { fields(first:20) { nodes { ... on ProjectV2IterationField { name configuration { iterations { id title startDate } } } } } } } }'
#GH_ITER_CURRENT=
#GH_ITER_NEXT=
